{
  "name": "bank-elhaz-multiplayer",
  "version": "1.0.0",
  "type": "module",
  "description": "Bank El Haz — Online multiplayer",
  "scripts": {
    "server": "node server.js",
    "client": "vite --port 5173",
    "dev": "node -e \"const{spawn}=require('child_process');const s=spawn('node',['server.js'],{stdio:'inherit'});const c=spawn('npx',['vite','--port','5173'],{stdio:'inherit'});process.on('SIGINT',()=>{s.kill();c.kill();process.exit()})\"",
    "start": "npm run build && node server.js",
    "build": "vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "socket.io": "^4.7.5"
  },
  "devDependencies": {
    "vite": "^6.3.3"
  }
}
